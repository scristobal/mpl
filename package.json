{
  "name": "mpl-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "playground",
    "packages/mpl-lang",
    "packages/mpl-codemirror"
  ],
  "scripts": {
    "dev": "npm run dev -w playground",
    "build:mpl": "./packages/build-mpl-wasm.sh",
    "build:codemirror": "npm run build -w @axiomhq/mpl-codemirror",
    "build:playground": "npm run build -w playground",
    "clean": "rm -rf node_modules playground/node_modules playground/wasm packages/mpl-codemirror/node_modules packages/mpl-codemirror/dist packages/mpl-lang"
  }
}
