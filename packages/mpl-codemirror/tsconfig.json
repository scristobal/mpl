{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "isolatedModules": true,
    "moduleDetection": "force",
    "declaration": true,
    "outDir": "dist",
    "strict": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
