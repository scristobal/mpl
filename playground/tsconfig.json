{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "paths": {
      "@axiomhq/mpl-codemirror": ["../packages/mpl-codemirror/src/index.ts"],
      "@axiomhq/mpl-codemirror/*": ["../packages/mpl-codemirror/*"],
      "@axiomhq/mpl-lang": ["../packages/mpl/mpl_lang.d.ts"]
    },
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true
  },
  "include": ["main.ts", "vite-env.d.ts"]
}

